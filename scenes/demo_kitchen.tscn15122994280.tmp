[node name="HintFlashAnimator" type="AnimationPlayer" parent="."]
unique_name_in_owner = true
root_node = NodePath("../Fridge")
libraries = {
&"": SubResource("AnimationLibrary_dmjcl")
}

[node name="Button" type="Button" parent="."]
layout_mode = 0
offset_left = -1.0
offset_top = 108.0
offset_right = 189.0
offset_bottom = 174.0
text = "summon customer"
script = ExtResource("18_so1dg")

[connection signal="ready" from="Fridge" to="Fridge" method="_on_ready"]
[connection signal="pressed" from="Fridge/FridgeTexture" to="Fridge" method="_on_fridge_pressed"]
[connection signal="visibility_changed" from="Fridge/FridgeHint" to="Fridge" method="_on_fridge_hint_visibility_changed"]
[connection signal="visibility_changed" from="Fridge/FridgeBubble" to="Fridge/FridgeBubble/FridgeFish" method="_on_visibility_changed"]
[connection signal="pressed" from="Fridge/FridgeBubble/FridgeFish" to="Fridge/FridgeBubble/FridgeFish" method="_on_pressed"]
[connection signal="pressed" from="Grill/CookedPickup" to="Grill/CookedPickup" method="_on_pressed"]
[connection signal="visibility_changed" from="Grill/CookedPickup" to="Grill/CookedPickup" method="_on_visibility_changed"]
[connection signal="pressed" from="CuttingBoard/CutPickup" to="CuttingBoard/CutPickup" method="_on_pressed"]
[connection signal="visibility_changed" from="CuttingBoard/CutPickup" to="CuttingBoard/CutPickup" method="_on_visibility_changed"]
[connection signal="pressed" from="Plate/Plate1" to="Plate/Plate1" method="_on_pressed"]
[connection signal="pressed" from="Plate 2/Plate2" to="Plate 2/Plate2" method="_on_pressed"]
[connection signal="pressed" from="Button" to="Button" method="_on_pressed"]
